# Copy this to .env.device and fill in your machine's local IP (run `ipconfig` to find it).
# Use this when testing on a physical Android device so API calls reach your dev machine.
#
# Run the app in device mode:
#   npm run dev -- --mode device
#
# Also set CAPACITOR_DEV_URL before syncing:
#   $env:CAPACITOR_DEV_URL="http://YOUR_IP:5173"; npx cap sync

VITE_API_URL=http://YOUR_LOCAL_IP:8000
